---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import IdeaCard from '../components/IdeaCard.astro';

const allIdee = await getCollection('ideas');
const idee = allIdee.sort((a, b) => b.data.data.getTime() - a.data.data.getTime());

const conteggio = {
  totale: idee.length,
  parcheggiata: idee.filter(i => i.data.stato === 'parcheggiata').length,
  'in-sviluppo': idee.filter(i => i.data.stato === 'in-sviluppo').length,
  completata: idee.filter(i => i.data.stato === 'completata').length,
};
---

<Layout title="Idee — Federico Casciero" description="Il parcheggio delle idee di Federico Casciero.">
  <section class="page-header">
    <h1 class="page-title">Parcheggio delle idee</h1>
    <p class="page-desc">
      Un posto dove metto le idee prima che svaniscano.
      Non tutte diventeranno qualcosa, ma meritano un posto dove aspettare.
    </p>
    <div class="stats">
      <span class="stat">
        <span class="stat-value">{conteggio.totale}</span>
        <span class="stat-label">totale</span>
      </span>
      <span class="stat-divider">·</span>
      <span class="stat">
        <span class="stat-value" style="color: #a1a1aa">{conteggio.parcheggiata}</span>
        <span class="stat-label">parcheggiate</span>
      </span>
      <span class="stat-divider">·</span>
      <span class="stat">
        <span class="stat-value" style="color: #fbbf24">{conteggio['in-sviluppo']}</span>
        <span class="stat-label">in sviluppo</span>
      </span>
      <span class="stat-divider">·</span>
      <span class="stat">
        <span class="stat-value" style="color: #34d399">{conteggio.completata}</span>
        <span class="stat-label">completate</span>
      </span>
    </div>
  </section>

  <div class="grid">
    {idee.map(idea => (
      <IdeaCard
        id={idea.id}
        titolo={idea.data.titolo}
        descrizione={idea.data.descrizione}
        stato={idea.data.stato}
        categoria={idea.data.categoria}
        tag={idea.data.tag}
        data={idea.data.data}
      />
    ))}
  </div>

  <div class="add-hint">
    <span class="add-hint-icon">+</span>
    <span>
      Per aggiungere un'idea, crea un file <code>.md</code> in <code>src/content/ideas/</code>
    </span>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 500px;
    margin-bottom: 1.5rem;
  }

  .stats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stat {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .stat-value {
    font-size: 1.1rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .stat-divider {
    color: var(--border);
    font-size: 1.1rem;
    margin: 0 0.15rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .add-hint {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--border);
    border-radius: 10px;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .add-hint-icon {
    font-size: 1.2rem;
    color: var(--muted);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .add-hint code {
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    color: var(--accent);
    opacity: 0.8;
  }
</style>
