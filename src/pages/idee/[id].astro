---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Giscus from '../../components/Giscus.astro';

export async function getStaticPaths() {
  const ideas = await getCollection('ideas');
  return ideas.map(idea => ({
    params: { id: idea.id },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const { Content } = await render(idea);

const statoLabel: Record<string, string> = {
  'parcheggiata': 'parcheggiata',
  'in-sviluppo': 'in sviluppo',
  'completata': 'completata',
  'abbandonata': 'abbandonata',
};

const dataFmt = idea.data.data.toLocaleDateString('it-IT', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<Layout title={`${idea.data.titolo} — Idee`} description={idea.data.descrizione}>
  <div class="back-link">
    <a href="/idee">← torna alle idee</a>
  </div>

  <article class="article">
    <header class="article-header">
      <div class="meta-row">
        <span class="categoria">{idea.data.categoria}</span>
        <span class={`stato stato--${idea.data.stato}`}>{statoLabel[idea.data.stato]}</span>
      </div>

      <h1 class="titolo">{idea.data.titolo}</h1>
      <p class="descrizione">{idea.data.descrizione}</p>

      <div class="bottom-meta">
        {idea.data.tag.length > 0 && (
          <div class="tags">
            {idea.data.tag.map(t => <span class="tag">#{t}</span>)}
          </div>
        )}
        <span class="data">Parcheggiata il {dataFmt}</span>
      </div>
    </header>

    <div class="content prose">
      <Content />
    </div>

    {idea.data.commenti && <Giscus />}
  </article>
</Layout>

<style>
  .back-link {
    margin-bottom: 2rem;
  }

  .back-link a {
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .back-link a:hover {
    color: var(--accent);
  }

  .article-header {
    padding-bottom: 2rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .categoria {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .stato {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .stato--parcheggiata { color: #a1a1aa; background: rgba(113,113,122,0.15); }
  .stato--in-sviluppo  { color: #fbbf24; background: rgba(251,191,36,0.15); }
  .stato--completata   { color: #34d399; background: rgba(52,211,153,0.15); }
  .stato--abbandonata  { color: #f87171; background: rgba(248,113,113,0.15); }

  .titolo {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .descrizione {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 600px;
  }

  .bottom-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.78rem;
    font-family: var(--font-mono, monospace);
    color: var(--accent);
    opacity: 0.8;
  }

  .data {
    font-size: 0.78rem;
    color: var(--muted);
    opacity: 0.6;
  }

  /* Prose styles */
  .prose :global(h2) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0.3rem;
  }

  .prose :global(code) {
    font-family: var(--font-mono, monospace);
    font-size: 0.85em;
    color: var(--accent);
    background: rgba(129,140,248,0.1);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
