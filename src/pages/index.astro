---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Federico Casciero — Fullstack Developer" description="Fullstack developer con focus su Java e Angular. Basato a Torino.">
  <section class="hero">
    <div class="hero-badge">disponibile</div>
    <h1 class="hero-name">Federico Casciero</h1>
    <p class="hero-tagline">
      Fullstack developer con 4+ anni di esperienza su stack Java/Angular.<br />
      Progetti enterprise nel banking, healthcare e manifatturiero.
    </p>
    <div class="hero-links">
      <a href="https://github.com/gufettonerd-arch" target="_blank" rel="noopener" class="link-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a href="mailto:gufetto.nerd@gmail.com" class="link-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </a>
      <a href="/idee" class="link-btn primary">
        Parcheggio idee →
      </a>
    </div>
  </section>

  <!-- STACK -->
  <section class="section">
    <h2 class="section-title">Stack</h2>
    <div class="skill-grid">
      <div class="skill-group">
        <span class="skill-label">Backend</span>
        <div class="skill-chips">
          <span class="chip">Java</span>
          <span class="chip">Spring Boot</span>
          <span class="chip">Hibernate</span>
          <span class="chip">MyBatis</span>
          <span class="chip">Python</span>
        </div>
      </div>
      <div class="skill-group">
        <span class="skill-label">Frontend</span>
        <div class="skill-chips">
          <span class="chip">Angular</span>
          <span class="chip">TypeScript</span>
          <span class="chip">HTML/CSS</span>
          <span class="chip">Flutter</span>
        </div>
      </div>
      <div class="skill-group">
        <span class="skill-label">Database</span>
        <div class="skill-chips">
          <span class="chip">PostgreSQL</span>
          <span class="chip">Oracle / PLSQL</span>
          <span class="chip">MongoDB</span>
          <span class="chip">MySQL</span>
          <span class="chip">Firebase</span>
        </div>
      </div>
      <div class="skill-group">
        <span class="skill-label">Infra / DevOps</span>
        <div class="skill-chips">
          <span class="chip">Docker</span>
          <span class="chip">Jenkins</span>
          <span class="chip">Maven</span>
          <span class="chip">Git</span>
          <span class="chip">Ubuntu</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ESPERIENZA -->
  <section class="section">
    <h2 class="section-title">Esperienza</h2>
    <div class="timeline">

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">VLC²</span>
          <span class="timeline-period">apr 2026 → presente</span>
        </div>
        <span class="timeline-role">Fullstack Developer — Alpitour</span>
        <p class="timeline-desc">
          Gestione e manutenzione di progetti legacy per la produzione di documenti di viaggio
          destinati ai clienti Alpitour.
        </p>
        <div class="timeline-tech">
          <span class="chip sm">Java</span><span class="chip sm">Legacy</span>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">VLC² · Reply-Data</span>
          <span class="timeline-period">set 2025 → apr 2026</span>
        </div>
        <span class="timeline-role">Fullstack Developer — Intesa San Paolo</span>
        <p class="timeline-desc">
          Sviluppo e ammodernamento di microservizi ad uso interno:
          riscrittura di codice legacy, aggiornamento dipendenze, bug fix e nuove funzionalità
          frontend (Angular/JS) e backend (Java).
        </p>
        <div class="timeline-tech">
          <span class="chip sm">Java</span><span class="chip sm">Angular</span><span class="chip sm">Spring Boot</span>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">VLC² · Reply-Healty</span>
          <span class="timeline-period">dic 2023 → ago 2025</span>
        </div>
        <span class="timeline-role">Fullstack Developer — Healthcare</span>
        <p class="timeline-desc">
          Tre progetti in ambito sanitario in parallelo.
          <strong>NPIA / Aria Lombardia</strong>: sviluppi e bug fix via Jira, REST API su Spring Boot, query SQL per analisi dati, frontend Angular.
          <strong>Cartella clinica / GPI</strong>: nuove funzionalità frontend (AngularJS) e backend Java, lettura/scrittura DB con Hibernate, scheduler per verifica dati, database Oracle e PostgreSQL.
          <strong>Pascoli Vaganti / Ministero della Salute</strong>: nuove feature Angular, API Java, tabelle e procedure Oracle.
        </p>
        <div class="timeline-tech">
          <span class="chip sm">AngularJS</span><span class="chip sm">Angular</span>
          <span class="chip sm">Java</span><span class="chip sm">Spring Boot</span>
          <span class="chip sm">Oracle</span><span class="chip sm">PostgreSQL</span>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">CGM Consulting · Reply-Blue</span>
          <span class="timeline-period">apr 2023 → dic 2023</span>
        </div>
        <span class="timeline-role">Fullstack Developer — Stellantis</span>
        <p class="timeline-desc">
          Sviluppo frontend (XHTML, JSP), servizi REST, batch, procedure e viste Oracle/PLSQL.
          Applicazioni standalone in Python 3.12.
          Alfa testing in ambiente di certificazione con documentazione annessa.
        </p>
        <div class="timeline-tech">
          <span class="chip sm">Java</span><span class="chip sm">Python</span>
          <span class="chip sm">Oracle / PLSQL</span><span class="chip sm">Primefaces</span>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">CGM Consulting · Reply-Technology</span>
          <span class="timeline-period">set 2022 → mar 2023</span>
        </div>
        <span class="timeline-role">Backend Developer — Intesa San Paolo (IsyBank)</span>
        <p class="timeline-desc">
          Creazione e sviluppo di microservizi e batch con Spring Boot, Hibernate e MyBatis.
          Integrazione eventi Kafka. Database PostgreSQL, H2 e MongoDB.
        </p>
        <div class="timeline-tech">
          <span class="chip sm">Spring Boot</span><span class="chip sm">Kafka</span>
          <span class="chip sm">Hibernate</span><span class="chip sm">PostgreSQL</span>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">CGM Consulting · Reply-Sytel</span>
          <span class="timeline-period">apr 2022 → ago 2022</span>
        </div>
        <span class="timeline-role">Fullstack Developer — Vodafone</span>
        <p class="timeline-desc">
          Aggiunta e modifica di funzionalità su console interna (JSF 1.2 + RichFaces 3.3).
          Upgrade completo a Java 8, JSF 2.2 e Primefaces 11.
        </p>
        <div class="timeline-tech">
          <span class="chip sm">Java</span><span class="chip sm">JSF</span>
          <span class="chip sm">Primefaces</span><span class="chip sm">Oracle</span>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="timeline-company">CGM Consulting · Reply-TamTamy</span>
          <span class="timeline-period">dic 2021 → mar 2022</span>
        </div>
        <span class="timeline-role">Fullstack Developer — Loro Piana</span>
        <p class="timeline-desc">
          Frontend con Angular 13 e TypeScript per aggiunta e modifica di funzionalità.
          Backend con Hibernate e Struts per la gestione delle nuove API.
        </p>
        <div class="timeline-tech">
          <span class="chip sm">Angular</span><span class="chip sm">TypeScript</span>
          <span class="chip sm">Hibernate</span><span class="chip sm">Struts</span>
        </div>
      </div>

    </div>
  </section>

  <!-- FORMAZIONE & ALTRO -->
  <section class="section two-col">
    <div>
      <h2 class="section-title">Formazione</h2>
      <div class="edu-list">
        <div class="edu-item">
          <span class="edu-name">Matematica per l'Ingegneria</span>
          <span class="edu-where">Politecnico di Torino</span>
          <span class="edu-note">Part-time, in pausa — 12 esami superati</span>
        </div>
        <div class="edu-item">
          <span class="edu-name">Corso Java Avanzato</span>
          <span class="edu-where">CGM Consulting — 2021</span>
        </div>
        <div class="edu-item">
          <span class="edu-name">Liceo Scientifico</span>
          <span class="edu-where">E. Majorana, Latina — 2014</span>
        </div>
      </div>
    </div>

    <div>
      <h2 class="section-title">Lingue & Altro</h2>
      <div class="misc-list">
        <div class="misc-item">
          <span class="misc-label">Italiano</span>
          <span class="misc-val">madrelingua</span>
        </div>
        <div class="misc-item">
          <span class="misc-label">Inglese</span>
          <span class="misc-val">B2</span>
        </div>
        <div class="misc-item">
          <span class="misc-label">Spagnolo</span>
          <span class="misc-val">A2</span>
        </div>
        <div class="misc-item">
          <span class="misc-label">Giapponese</span>
          <span class="misc-val">in studio</span>
        </div>
        <div class="misc-divider"></div>
        <div class="misc-item">
          <span class="misc-label">AGESCI Scout</span>
          <span class="misc-val">capo educatore dal 2016</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero {
    padding: 3rem 0 4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #34d399;
    background: rgba(52, 211, 153, 0.1);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-name {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-tagline {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.45rem 0.9rem;
    border-radius: 7px;
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--surface);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .link-btn:hover { color: var(--text); border-color: #3f3f46; }

  .link-btn.primary {
    color: var(--accent);
    border-color: rgba(129, 140, 248, 0.3);
    background: rgba(129, 140, 248, 0.08);
  }

  .link-btn.primary:hover {
    background: rgba(129, 140, 248, 0.14);
    border-color: rgba(129, 140, 248, 0.5);
  }

  /* SECTIONS */
  .section { margin-bottom: 3.5rem; }

  .section-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  /* STACK */
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .skill-group { display: flex; flex-direction: column; gap: 0.6rem; }

  .skill-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
    opacity: 0.65;
  }

  .skill-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  .chip {
    font-size: 0.78rem;
    font-family: var(--font-mono, monospace);
    padding: 0.2rem 0.6rem;
    border-radius: 5px;
    background: rgba(129, 140, 248, 0.08);
    border: 1px solid rgba(129, 140, 248, 0.18);
    color: var(--accent);
    font-weight: 500;
  }

  .chip.sm { font-size: 0.72rem; padding: 0.15rem 0.5rem; }

  /* TIMELINE */
  .timeline { display: flex; flex-direction: column; gap: 0; }

  .timeline-item {
    padding: 1.4rem 0 1.4rem 1.25rem;
    border-left: 1px solid var(--border);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -4px;
    top: 1.75rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--border);
    border: 1px solid var(--bg);
  }

  .timeline-item:first-child::before { background: var(--accent); }

  .timeline-meta {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .timeline-company {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-period {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono, monospace);
    opacity: 0.6;
  }

  .timeline-role {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .timeline-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 620px;
  }

  .timeline-tech { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.2rem; }

  /* TWO COL */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 600px) {
    .two-col { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* EDU */
  .edu-list { display: flex; flex-direction: column; gap: 1.1rem; }

  .edu-item { display: flex; flex-direction: column; gap: 0.15rem; }

  .edu-name { font-size: 0.9rem; font-weight: 600; color: var(--text); }

  .edu-where { font-size: 0.8rem; color: var(--muted); }

  .edu-note {
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.6;
    font-style: italic;
  }

  /* MISC */
  .misc-list { display: flex; flex-direction: column; gap: 0.6rem; }

  .misc-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    font-size: 0.875rem;
  }

  .misc-label { color: var(--muted); }

  .misc-val { color: var(--text); font-weight: 500; font-size: 0.82rem; }

  .misc-divider {
    height: 1px;
    background: var(--border);
    margin: 0.4rem 0;
  }
</style>
